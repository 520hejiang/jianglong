#!/bin/bash

RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
PLAIN="\033[0m"

red()    { echo -e "${RED}$1${PLAIN}"; }
green()  { echo -e "${GREEN}$1${PLAIN}"; }
yellow() { echo -e "${YELLOW}$1${PLAIN}"; }

[[ $EUID -ne 0 ]] && red "请使用 root 运行" && exit 1

XRAY_CONFIG="/usr/local/etc/xray/config.json"
CERT_DIR="/usr/local/etc/xray/cert"
CLIENT_DIR="/root/vless-ws"
WARP_SOCKS="127.0.0.1"
WARP_PORT="40000"

# ────────────────────────────────────────────
# 获取公网 IP
# ────────────────────────────────────────────
get_ip() {
  IP=$(curl -s --max-time 5 https://api.ipify.org 2>/dev/null)
  [[ -z "$IP" ]] && IP=$(curl -s --max-time 5 https://ifconfig.me 2>/dev/null)
  [[ -z "$IP" ]] && red "无法获取公网 IP，请检查网络" && exit 1
  yellow "服务器 IP: $IP"
}

# ────────────────────────────────────────────
# 安装基础依赖
# ────────────────────────────────────────────
install_deps() {
  yellow "安装基础依赖..."
  apt-get update -qq
  apt-get install -y -qq curl wget unzip socat openssl uuid-runtime lsb-release gnupg python3 2>/dev/null || \
  yum install -y -q curl wget unzip openssl util-linux python3 2>/dev/null || true
  green "依赖安装完成"
}

# ────────────────────────────────────────────
# 安装 Xray-core
# ────────────────────────────────────────────
install_xray() {
  yellow "安装 Xray-core..."
  bash <(curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh) install 2>&1 | tail -5
  [[ ! -f /usr/local/bin/xray ]] && red "Xray 安装失败，请检查网络" && exit 1
  green "Xray 安装成功: $(/usr/local/bin/xray version | head -1)"
}

# ────────────────────────────────────────────
# 收集参数
# ────────────────────────────────────────────
collect_params() {
  echo ""
  yellow "=== 参数配置 ==="
  echo ""

  read -rp "请输入你的域名 (例: vpn.example.com): " DOMAIN
  [[ -z "$DOMAIN" ]] && red "域名不能为空" && exit 1

  read -rp "请输入 ACME 邮箱: " EMAIL
  [[ -z "$EMAIL" ]] && red "邮箱不能为空" && exit 1

  RAND_PATH=$(openssl rand -hex 8)
  read -rp "请输入 WebSocket 路径 [默认: /${RAND_PATH}]: " WS_PATH_INPUT
  WS_PATH="/${WS_PATH_INPUT:-$RAND_PATH}"
  [[ "${WS_PATH:0:1}" != "/" ]] && WS_PATH="/$WS_PATH"

  UUID=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen)

  echo ""
  yellow "请确认以下信息："
  echo "  域名   : $DOMAIN"
  echo "  WS路径 : $WS_PATH"
  echo "  UUID   : $UUID"
  echo ""
  yellow "重要提示："
  yellow "  1. 域名 A 记录必须解析到 $IP"
  yellow "  2. 申请证书时 Cloudflare 橙色云必须关闭（灰色），申请完再开"
  yellow "  3. Cloudflare SSL/TLS 加密模式设为【完全(严格)】"
  yellow "  4. Cloudflare 网络设置里开启【WebSockets】"
  echo ""
  read -rp "确认继续？[y/N]: " CONFIRM
  [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]] && red "已取消" && exit 1
}

# ────────────────────────────────────────────
# 系统优化
# ────────────────────────────────────────────
optimize() {
  local SYSCTL=/etc/sysctl.conf

  add_sysctl() {
    grep -q "^$1" "$SYSCTL" || echo "$1" >> "$SYSCTL"
  }

  add_sysctl "net.ipv4.ip_forward=1"
  add_sysctl "net.ipv6.conf.all.forwarding=1"
  add_sysctl "net.core.default_qdisc=fq"
  add_sysctl "net.ipv4.tcp_congestion_control=bbr"
  add_sysctl "net.core.rmem_max=33554432"
  add_sysctl "net.core.wmem_max=33554432"
  sysctl -p >/dev/null 2>&1

  iptables -C INPUT -p tcp --dport 443 -j ACCEPT 2>/dev/null \
    || iptables -I INPUT -p tcp --dport 443 -j ACCEPT
  iptables -C INPUT -p tcp --dport 80 -j ACCEPT 2>/dev/null \
    || iptables -I INPUT -p tcp --dport 80 -j ACCEPT
  iptables -C FORWARD -j ACCEPT 2>/dev/null \
    || iptables -I FORWARD -j ACCEPT

  green "系统优化完成"
}

# ────────────────────────────────────────────
# 申请 TLS 证书
# ────────────────────────────────────────────
get_cert() {
  yellow "安装 acme.sh 并申请证书..."

  curl -fsSL https://get.acme.sh | bash -s email="$EMAIL" >/dev/null 2>&1
  ACME="$HOME/.acme.sh/acme.sh"
  [[ ! -f "$ACME" ]] && red "acme.sh 安装失败" && exit 1

  "$ACME" --set-default-ca --server letsencrypt >/dev/null 2>&1

  # 停掉可能占用 80 端口的服务
  systemctl stop nginx 2>/dev/null
  systemctl stop apache2 2>/dev/null
  systemctl stop httpd 2>/dev/null

  "$ACME" --issue -d "$DOMAIN" --standalone --httpport 80 \
    --keylength ec-256 2>&1 | tail -10

  if [[ $? -ne 0 ]]; then
    red "证书申请失败，请检查："
    red "  1. 域名 $DOMAIN 的 A 记录是否指向 $IP"
    red "  2. Cloudflare 橙色云是否已关闭（灰色）"
    red "  3. 防火墙 TCP 80 是否放行"
    exit 1
  fi

  mkdir -p "$CERT_DIR"
  "$ACME" --install-cert -d "$DOMAIN" --ecc \
    --cert-file      "$CERT_DIR/cert.crt" \
    --key-file       "$CERT_DIR/cert.key" \
    --fullchain-file "$CERT_DIR/fullchain.crt" \
    --reloadcmd      "systemctl restart xray 2>/dev/null || true"

  # 644 让 nobody 用户可读
  chmod 644 "$CERT_DIR/cert.key"
  chmod 644 "$CERT_DIR/fullchain.crt"
  chmod 644 "$CERT_DIR/cert.crt"

  green "证书申请成功"
}

# ────────────────────────────────────────────
# 安装 Cloudflare Warp
# ────────────────────────────────────────────
install_warp() {
  yellow "安装 Cloudflare Warp..."

  if command -v warp-cli &>/dev/null; then
    green "Warp 已安装，跳过"
    return
  fi

  if command -v apt-get &>/dev/null; then
    apt-get install -y -qq lsb-release gnupg 2>/dev/null || true

    curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg \
      | gpg --yes --dearmor --output /usr/share/keyrings/cloudflare-warp-archive-keyring.gpg

    CODENAME=$(lsb_release -cs 2>/dev/null || (. /etc/os-release && echo "$VERSION_CODENAME"))
    echo "deb [signed-by=/usr/share/keyrings/cloudflare-warp-archive-keyring.gpg] https://pkg.cloudflareclient.com/ ${CODENAME} main" \
      > /etc/apt/sources.list.d/cloudflare-client.list

    apt-get update -qq
    apt-get install -y -qq cloudflare-warp

  elif command -v yum &>/dev/null; then
    curl -fsSL https://pkg.cloudflareclient.com/cloudflare-warp-ascii.repo \
      > /etc/yum.repos.d/cloudflare-warp.repo
    yum install -y cloudflare-warp
  else
    red "不支持的系统，请手动安装 cloudflare-warp" && exit 1
  fi

  [[ ! $(command -v warp-cli) ]] && red "Warp 安装失败" && exit 1
  green "Warp 安装成功"
}

# ────────────────────────────────────────────
# 配置并启动 Warp
# ────────────────────────────────────────────
setup_warp() {
  yellow "配置 Warp..."

  systemctl enable warp-svc >/dev/null 2>&1
  systemctl restart warp-svc
  sleep 3

  # 注册（已注册则跳过）
  if ! warp-cli status 2>/dev/null | grep -q "registered\|Connected"; then
    warp-cli registration new
    sleep 2
  fi

  # 设置代理模式和端口
  warp-cli mode proxy
  warp-cli proxy port $WARP_PORT

  # 连接
  warp-cli connect
  sleep 5

  STATUS=$(warp-cli status 2>/dev/null)
  if echo "$STATUS" | grep -q "Connected"; then
    green "Warp 连接成功"
  else
    red "Warp 连接失败，状态: $STATUS"
    red "部分机房 UDP 受限可能导致 Warp 无法连接"
    exit 1
  fi

  sleep 2
  if ! ss -tlnp | grep -q ":$WARP_PORT"; then
    red "Warp socks5 端口 $WARP_PORT 未监听" && exit 1
  fi
  green "Warp socks5 监听在 $WARP_SOCKS:$WARP_PORT"
}

# ────────────────────────────────────────────
# 生成 Xray 配置（含 Warp 出站）
# ────────────────────────────────────────────
gen_xray_config() {
  yellow "生成 Xray 配置..."
  mkdir -p /usr/local/etc/xray

  cat > "$XRAY_CONFIG" << EOF
{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$UUID",
            "level": 0
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "$CERT_DIR/fullchain.crt",
              "keyFile": "$CERT_DIR/cert.key"
            }
          ]
        },
        "wsSettings": {
          "path": "$WS_PATH",
          "host": "$DOMAIN"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "warp",
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "$WARP_SOCKS",
            "port": $WARP_PORT
          }
        ]
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "blocked",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "warp"
      }
    ]
  }
}
EOF

  green "Xray 配置生成完成"
}

# ────────────────────────────────────────────
# 启动 Xray 服务
# ────────────────────────────────────────────
start_xray() {
  systemctl daemon-reload
  systemctl enable xray >/dev/null 2>&1
  systemctl restart xray
  sleep 3

  if systemctl is-active --quiet xray; then
    green "Xray 服务启动成功"
  else
    red "Xray 服务启动失败，查看日志:"
    journalctl -u xray -n 30 --no-pager
    exit 1
  fi
}

# ────────────────────────────────────────────
# 生成客户端链接
# ────────────────────────────────────────────
gen_client_output() {
  mkdir -p "$CLIENT_DIR"

  ENCODED_PATH=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${WS_PATH}', safe='/'))" 2>/dev/null || echo "${WS_PATH}")
  LINK="vless://${UUID}@${DOMAIN}:443?encryption=none&security=tls&sni=${DOMAIN}&type=ws&host=${DOMAIN}&path=${ENCODED_PATH}#VLESS-WS-CF"
  echo "$LINK" > "$CLIENT_DIR/link.txt"

  cat > "$CLIENT_DIR/client.json" << EOF
{
  "备注": "VLESS-WS-TLS-CF-Warp",
  "地址": "$DOMAIN",
  "端口": 443,
  "UUID": "$UUID",
  "加密": "none",
  "传输": "ws",
  "WS路径": "$WS_PATH",
  "WS Host": "$DOMAIN",
  "TLS": "tls",
  "SNI": "$DOMAIN",
  "指纹": "chrome"
}
EOF
}

# ────────────────────────────────────────────
# 验证 Warp 出口 IP
# ────────────────────────────────────────────
verify_warp_ip() {
  yellow "验证 Warp 出口 IP..."
  sleep 2
  WARP_IP=$(curl -s --max-time 10 \
    --proxy "socks5://$WARP_SOCKS:$WARP_PORT" \
    https://api.ipify.org 2>/dev/null)

  if [[ -n "$WARP_IP" ]]; then
    green "Warp 出口 IP: $WARP_IP（目标网站看到的是这个 Cloudflare IP）"
  else
    yellow "无法自动验证 Warp 出口 IP，请连上节点后访问 ipinfo.io 手动确认"
  fi
}

# ────────────────────────────────────────────
# 主流程
# ────────────────────────────────────────────
main() {
  clear
  green "========================================"
  green "  VLESS + WS + TLS + CF + Warp"
  green "       一键安装脚本"
  green "========================================"
  echo ""

  get_ip
  install_deps
  install_xray
  collect_params
  optimize
  get_cert
  install_warp
  setup_warp
  gen_xray_config
  start_xray
  gen_client_output
  verify_warp_ip

  echo ""
  green "========================================"
  green "           安装完成！"
  green "========================================"
  echo ""
  echo "域名   : $DOMAIN"
  echo "端口   : 443"
  echo "UUID   : $UUID"
  echo "WS路径 : $WS_PATH"
  echo ""
  yellow "连接链接（直接导入客户端）："
  cat "$CLIENT_DIR/link.txt"
  echo ""
  yellow "═══ Cloudflare 配置步骤 ═══"
  echo "1. DNS → $DOMAIN 的 A 记录 → 开启橙色云"
  echo "2. SSL/TLS → 加密模式 → 【完全(严格)】"
  echo "3. SSL/TLS → 边缘证书 → 开启【TLS 1.3】"
  echo "4. 网络 → WebSockets → 开启"
  echo ""
  yellow "═══ 流量路径 ═══"
  echo "手机 → Cloudflare CDN → VPS → Warp → 目标网站"
  echo "目标网站看到的是 Cloudflare Warp IP，不是 VPS IP"
  echo ""
  echo "服务管理 : systemctl restart xray"
  echo "Warp状态 : warp-cli status"
  echo "查看日志 : journalctl -u xray -f"
  echo "客户端配置: $CLIENT_DIR/client.json"
  echo ""
}

main
