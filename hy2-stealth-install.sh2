#!/bin/bash
set -Eeuo pipefail

RED="\033[31m"; GREEN="\033[32m"; YELLOW="\033[33m"; NC="\033[0m"
r(){ echo -e "${RED}$1${NC}"; }
g(){ echo -e "${GREEN}$1${NC}"; }
y(){ echo -e "${YELLOW}$1${NC}"; }

[[ $EUID -ne 0 ]] && r "必须root运行" && exit 1

XRAY_DIR="/usr/local/etc/xray"
CERT_DIR="$XRAY_DIR/cert"
CONFIG="$XRAY_DIR/config.json"
WARP_PORT=40000

# =====================
# 公网IP
# =====================
get_ip(){
  IP=$(curl -s https://api.ipify.org || true)
  [[ -z "$IP" ]] && r "无法获取IP" && exit 1
  y "IP: $IP"
}

# =====================
# DNS校验
# =====================
check_dns(){
  RES=$(dig +short "$DOMAIN" | tail -n1)
  [[ "$RES" != "$IP" ]] && r "DNS不匹配 $RES != $IP" && exit 1
  g "DNS OK"
}

# =====================
# 端口检查
# =====================
check_port(){
  ss -tlnp | grep -q ":80 " && r "80被占用" && exit 1
  ss -tlnp | grep -q ":443 " && r "443被占用" && exit 1
}

# =====================
# 依赖
# =====================
deps(){
  apt update -y
  apt install -y curl wget socat openssl uuid-runtime dnsutils
}

# =====================
# Xray
# =====================
xray_install(){
  bash <(curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh)
}

# =====================
# 参数
# =====================
params(){
  read -rp "域名: " DOMAIN
  read -rp "邮箱: " EMAIL
  UUID=$(cat /proc/sys/kernel/random/uuid)
  WS="/$(openssl rand -hex 6)"
}

# =====================
# ACME（修复核心）
# =====================
cert(){
  y "申请证书..."

  curl -s https://get.acme.sh | sh -s email="$EMAIL"
  ACME="$HOME/.acme.sh/acme.sh"

  systemctl stop nginx 2>/dev/null || true

  set +e
  OUT=$("$ACME" --issue -d "$DOMAIN" --standalone --httpport 80 2>&1)
  RET=$?
  set -e

  echo "$OUT"

  [[ $RET -ne 0 ]] && r "证书失败" && exit 1

  mkdir -p "$CERT_DIR"

  "$ACME" --install-cert -d "$DOMAIN" \
    --cert-file "$CERT_DIR/cert.crt" \
    --key-file "$CERT_DIR/cert.key" \
    --fullchain-file "$CERT_DIR/fullchain.crt"

  [[ ! -s "$CERT_DIR/fullchain.crt" ]] && r "证书缺失" && exit 1
  [[ ! -s "$CERT_DIR/cert.key" ]] && r "KEY缺失" && exit 1

  chmod 600 "$CERT_DIR/cert.key"
  chmod 644 "$CERT_DIR/fullchain.crt"

  g "证书OK"
}

# =====================
# Warp
# =====================
warp(){
  curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg | gpg --dearmor -o /usr/share/keyrings/warp.gpg

  echo "deb [signed-by=/usr/share/keyrings/warp.gpg] https://pkg.cloudflareclient.com/ bookworm main" \
    > /etc/apt/sources.list.d/warp.list

  apt update -y
  apt install -y cloudflare-warp

  systemctl enable warp-svc
  systemctl restart warp-svc

  warp-cli registration new || true
  warp-cli mode proxy
  warp-cli proxy port $WARP_PORT
  warp-cli connect

  sleep 3
  warp-cli status | grep -q Connected || {
    r "Warp失败"
    exit 1
  }

  g "Warp OK"
}

# =====================
# 配置
# =====================
config(){
  mkdir -p "$XRAY_DIR"

  cat > "$CONFIG" <<EOF
{
  "inbounds":[
    {
      "port":443,
      "protocol":"vless",
      "settings":{"clients":[{"id":"$UUID"}],"decryption":"none"},
      "streamSettings":{
        "network":"ws",
        "security":"tls",
        "tlsSettings":{
          "certificates":[{"certificateFile":"$CERT_DIR/fullchain.crt","keyFile":"$CERT_DIR/cert.key"}]
        },
        "wsSettings":{"path":"$WS"}
      }
    }
  ],
  "outbounds":[{"protocol":"freedom"}]
}
EOF
}

# =====================
# Xray启动前测试
# =====================
start(){
  /usr/local/bin/xray run -test -config "$CONFIG" || {
    r "配置错误"
    exit 1
  }

  systemctl restart xray
  systemctl enable xray

  systemctl is-active --quiet xray || {
    r "Xray失败"
    exit 1
  }

  g "Xray OK"
}

# =====================
# 主流程
# =====================
main(){
  get_ip
  deps
  xray_install
  params
  check_port
  check_dns
  cert
  warp
  config
  start

  g "========================"
  g "安装完成"
  echo "vless://$UUID@$DOMAIN:443"
}

main