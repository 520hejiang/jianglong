#!/bin/bash

RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
PLAIN="\033[0m"

red()    { echo -e "${RED}$1${PLAIN}"; }
green()  { echo -e "${GREEN}$1${PLAIN}"; }
yellow() { echo -e "${YELLOW}$1${PLAIN}"; }

[[ $EUID -ne 0 ]] && red "请使用 root 运行" && exit 1

# ────────────────────────────────────────────
# 依赖检查 & 安装
# ────────────────────────────────────────────
install_deps() {
  yellow "检查并安装依赖..."
  apt-get update -qq
  apt-get install -y -qq curl wget unzip socat openssl uuid-runtime 2>/dev/null || \
  yum install -y -q curl wget unzip openssl util-linux 2>/dev/null || true
}

# ────────────────────────────────────────────
# 安装 Xray-core
# ────────────────────────────────────────────
install_xray() {
  yellow "安装 Xray-core..."
  bash <(curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh) install 2>&1 | tail -5
  [[ ! -f /usr/local/bin/xray ]] && red "Xray 安装失败，请检查网络" && exit 1
  green "Xray 安装成功: $(/usr/local/bin/xray version | head -1)"
}

# ────────────────────────────────────────────
# 获取公网 IP
# ────────────────────────────────────────────
get_ip() {
  IP=$(curl -s --max-time 5 https://api.ipify.org 2>/dev/null)
  [[ -z "$IP" ]] && IP=$(curl -s --max-time 5 https://ifconfig.me 2>/dev/null)
  [[ -z "$IP" ]] && red "无法获取公网 IP" && exit 1
  yellow "服务器 IP: $IP"
}

# ────────────────────────────────────────────
# 交互式收集参数
# ────────────────────────────────────────────
collect_params() {
  echo ""
  yellow "=== 参数配置 ==="
  echo ""

  # 域名
  read -rp "请输入你的域名 (例: vpn.example.com): " DOMAIN
  [[ -z "$DOMAIN" ]] && red "域名不能为空" && exit 1

  # 邮箱（ACME）
  read -rp "请输入 ACME 邮箱: " EMAIL
  [[ -z "$EMAIL" ]] && red "邮箱不能为空" && exit 1

  # WebSocket 路径（随机默认值）
  RAND_PATH=$(openssl rand -hex 8)
  read -rp "请输入 WebSocket 路径 [默认: /${RAND_PATH}]: " WS_PATH_INPUT
  WS_PATH="/${WS_PATH_INPUT:-$RAND_PATH}"
  # 确保路径以 / 开头
  [[ "${WS_PATH:0:1}" != "/" ]] && WS_PATH="/$WS_PATH"

  # UUID
  UUID=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen)
  yellow "生成 UUID: $UUID"

  echo ""
  yellow "请确认以下信息："
  echo "  域名    : $DOMAIN"
  echo "  WS路径  : $WS_PATH"
  echo "  UUID    : $UUID"
  echo ""
  yellow "重要：请确保域名 A 记录已解析到 $IP，且 Cloudflare 橙色云已开启"
  yellow "Cloudflare SSL/TLS 加密模式请设置为【完全(严格)】"
  echo ""
  read -rp "确认继续？[y/N]: " CONFIRM
  [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]] && red "已取消" && exit 1
}

# ────────────────────────────────────────────
# 申请 TLS 证书（acme.sh）
# ────────────────────────────────────────────
get_cert() {
  yellow "安装 acme.sh 并申请证书..."

  # 安装 acme.sh
  curl -fsSL https://get.acme.sh | bash -s email="$EMAIL" >/dev/null 2>&1
  ACME="$HOME/.acme.sh/acme.sh"  # 直接用绝对路径，不依赖 source ~/.bashrc
  [[ ! -f "$ACME" ]] && red "acme.sh 安装失败" && exit 1

  # 切换默认 CA 为 Let's Encrypt
  "$ACME" --set-default-ca --server letsencrypt >/dev/null 2>&1

  # 申请证书（需要 80 端口空闲）
  # 如果 80 端口被占用先停掉 nginx/apache
  systemctl stop nginx 2>/dev/null; systemctl stop apache2 2>/dev/null; systemctl stop httpd 2>/dev/null

  "$ACME" --issue -d "$DOMAIN" --standalone --httpport 80 \
    --keylength ec-256 2>&1 | tail -10

  if [[ $? -ne 0 ]]; then
    red "证书申请失败，请检查："
    red "  1. 域名 $DOMAIN 的 A 记录是否指向 $IP"
    red "  2. Cloudflare 橙色云是否已关闭（申请证书时必须关闭，申请完再开）"
    red "  3. 防火墙 TCP 80 是否放行"
    exit 1
  fi

  # 安装证书到指定目录
  mkdir -p /etc/xray/cert
  "$ACME" --install-cert -d "$DOMAIN" --ecc \
    --cert-file    /etc/xray/cert/cert.crt \
    --key-file     /etc/xray/cert/cert.key \
    --fullchain-file /etc/xray/cert/fullchain.crt \
    --reloadcmd "systemctl restart xray 2>/dev/null || true"

  chmod 600 /etc/xray/cert/cert.key
  green "证书申请成功"
}

# ────────────────────────────────────────────
# 生成 Xray 配置
# ────────────────────────────────────────────
gen_xray_config() {
  yellow "生成 Xray 配置..."
  mkdir -p /etc/xray

  cat > /etc/xray/config.json <<EOF
{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$UUID",
            "level": 0
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "/etc/xray/cert/fullchain.crt",
              "keyFile": "/etc/xray/cert/cert.key"
            }
          ]
        },
        "wsSettings": {
          "path": "$WS_PATH",
          "headers": {
            "Host": "$DOMAIN"
          }
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "blocked"
    }
  ]
}
EOF

  green "Xray 配置生成完成"
}

# ────────────────────────────────────────────
# systemd 服务
# ────────────────────────────────────────────
start_service() {
  # Xray 安装脚本已创建 systemd 服务，直接 reload 即可
  systemctl daemon-reload
  systemctl enable xray >/dev/null 2>&1
  systemctl restart xray

  sleep 2
  if systemctl is-active --quiet xray; then
    green "Xray 服务启动成功"
  else
    red "Xray 服务启动失败，查看日志:"
    journalctl -u xray -n 30 --no-pager
    exit 1
  fi
}

# ────────────────────────────────────────────
# 系统优化 & 防火墙
# ────────────────────────────────────────────
optimize() {
  local SYSCTL=/etc/sysctl.conf

  add_sysctl() {
    grep -q "^$1" "$SYSCTL" || echo "$1" >> "$SYSCTL"
  }

  add_sysctl "net.ipv4.ip_forward=1"
  add_sysctl "net.ipv6.conf.all.forwarding=1"
  add_sysctl "net.core.default_qdisc=fq"
  add_sysctl "net.ipv4.tcp_congestion_control=bbr"
  add_sysctl "net.core.rmem_max=33554432"
  add_sysctl "net.core.wmem_max=33554432"
  sysctl -p >/dev/null 2>&1

  # 放行 443（TCP，Xray 监听）和 80（TCP，ACME 证书申请）
  iptables -C INPUT -p tcp --dport 443 -j ACCEPT 2>/dev/null \
    || iptables -I INPUT -p tcp --dport 443 -j ACCEPT
  iptables -C INPUT -p tcp --dport 80 -j ACCEPT 2>/dev/null \
    || iptables -I INPUT -p tcp --dport 80 -j ACCEPT
  iptables -C FORWARD -j ACCEPT 2>/dev/null \
    || iptables -I FORWARD -j ACCEPT
}

# ────────────────────────────────────────────
# 生成客户端输出
# ────────────────────────────────────────────
gen_client_output() {
  mkdir -p /root/vless-ws

  # vless:// share link（path 保留斜杠，避免 %2F 导致客户端解析失败）
  ENCODED_PATH=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${WS_PATH}', safe='/'))" 2>/dev/null || echo "${WS_PATH}")
  LINK="vless://${UUID}@${DOMAIN}:443?encryption=none&security=tls&sni=${DOMAIN}&type=ws&host=${DOMAIN}&path=${ENCODED_PATH}#VLESS-WS-CF"
  echo "$LINK" > /root/vless-ws/link.txt

  # 客户端参考配置（适用于 V2rayNG / NekoBox JSON 导入）
  cat > /root/vless-ws/client.json <<EOF
{
  "备注": "VLESS-WS-TLS-CF",
  "地址": "$DOMAIN",
  "端口": 443,
  "UUID": "$UUID",
  "加密": "none",
  "传输": "ws",
  "WS路径": "$WS_PATH",
  "WS Host": "$DOMAIN",
  "TLS": "tls",
  "SNI": "$DOMAIN",
  "指纹": "chrome"
}
EOF
}

# ────────────────────────────────────────────
# 主流程
# ────────────────────────────────────────────
main() {
  clear
  green "========================================"
  green "    VLESS + WebSocket + TLS + CF CDN"
  green "         安装脚本"
  green "========================================"
  echo ""

  get_ip
  install_deps
  install_xray
  collect_params
  optimize
  get_cert
  gen_xray_config
  start_service
  gen_client_output

  echo ""
  green "========================================"
  green "           安装完成！"
  green "========================================"
  echo ""
  echo "域名    : $DOMAIN"
  echo "端口    : 443"
  echo "UUID    : $UUID"
  echo "传输    : WebSocket"
  echo "WS路径  : $WS_PATH"
  echo "TLS     : 开启"
  echo ""
  yellow "连接链接 (直接导入客户端):"
  cat /root/vless-ws/link.txt
  echo ""
  yellow "═══ Cloudflare 配置步骤 ═══"
  echo "1. DNS → $DOMAIN 的 A 记录 → 开启橙色云（代理）"
  echo "2. SSL/TLS → 加密模式 → 选【完全(严格)】"
  echo "3. SSL/TLS → 边缘证书 → 开启【TLS 1.3】"
  echo "4. 网络 → WebSockets → 开启"
  echo ""
  yellow "═══ 证书申请时的注意事项 ═══"
  echo "申请证书时需临时关闭橙色云（灰色），申请完成后再开启"
  echo ""
  echo "服务管理 : systemctl restart xray"
  echo "查看日志 : journalctl -u xray -f"
  echo "客户端配置: /root/vless-ws/client.json"
  echo ""
}

main
