{
  "name": "xianxia-novel-generator",
  "version": "0.1.0",
  "private": true,
  "description": "全自动 AI 修仙小说生成系统 (Cloudflare Workers + D1 + KV + Queues)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute novel_db --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute novel_db --remote --file=./schema.sql",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.60.0"
  }
}
